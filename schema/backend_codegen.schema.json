{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BackendCodegen",
  "description": "Backend source code generation output schema.",
  "type": "object",
  "required": [
    "generated_files"
  ],
  "properties": {
    "generated_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "content"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "생성될 파일 경로"
          },
          "content": {
            "type": "string",
            "description": "파일 전체 소스코드"
          }
        }
      }
    }
  }
}