{
  "project_metadata": {
    "name": "GIS Insight Viewer",
    "description": "비전문가를 위한 GeoJSON 데이터 시각화 및 공간 분석 웹 애플리케이션",
    "tech_stack": {
      "framework": "React (Vite)",
      "language": "TypeScript",
      "state_management": "Zustand",
      "data_fetching": "React Query",
      "map_library": "Leaflet"
    }
  },
  "folders": [
    {
      "path": "src/pages",
      "purpose": "애플리케이션의 각 라우트별 페이지 컴포넌트를 관리합니다."
    },
    {
      "path": "src/components",
      "purpose": "여러 기능에서 재사용되는 공통 UI 컴포넌트를 관리합니다."
    },
    {
      "path": "src/features",
      "purpose": "기능별(Map, Upload, Analysis 등) 도메인 로직과 전용 컴포넌트를 관리하는 Feature-Based 구조의 핵심 폴더입니다."
    },
    {
      "path": "src/hooks",
      "purpose": "전역적으로 사용되는 커스텀 훅 및 API 통신(React Query) 훅을 관리합니다."
    },
    {
      "path": "src/services",
      "purpose": "API 클라이언트 설정 및 외부 라이브러리 연동 로직을 관리합니다."
    },
    {
      "path": "src/stores",
      "purpose": "Zustand를 이용한 클라이언트 측 전역 상태를 관리합니다."
    },
    {
      "path": "src/types",
      "purpose": "애플리케이션 전반에서 사용되는 공통 타입 및 인터페이스를 정의합니다."
    },
    {
      "path": "src/routes",
      "purpose": "애플리케이션의 라우팅 구성 및 경로 정의를 관리합니다."
    },
    {
      "path": "src/layouts",
      "purpose": "페이지의 공통 레이아웃 컴포넌트를 관리합니다."
    },
    {
      "path": "src/utils",
      "purpose": "공통 유틸리티 함수 및 상수 정의를 관리합니다."
    }
  ],
  "files": [
    {
