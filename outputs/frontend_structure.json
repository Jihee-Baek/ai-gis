              "name": "zoom",
              "type": "number"
            },
            {
              "name": "center",
              "type": "[number, number]"
            },
            {
              "name": "layers",
              "type": "LayerInfo[]"
            }
          ],
          "actions": [
            "setZoom",
            "setCenter",
            "addLayer",
            "removeLayer",
            "toggleLayerVisibility"
          ]
        }
      ]
    },
