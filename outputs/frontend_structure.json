    {
      "path": "src/stores/mapStore.ts",
      "type": "store",
      "purpose": "지도 줌 레벨, 중심 좌표, 활성 레이어 상태 관리",
      "exported_symbols": [
        {
          "name": "useMapStore",
          "purpose": "지도 관련 전역 상태를 관리하는 Zustand 스토어입니다.",
          "state": [
